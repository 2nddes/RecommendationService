{
    "info": {
        "name": "RecommendationService API (Code-Aligned)",
        "description": "Code-aligned Postman collection for RecommendationService. Base path: /api/v1.",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "variable": [
        { "key": "base_url", "value": "http://127.0.0.1:5000", "type": "string" },
        { "key": "internal_secret", "value": "", "type": "string" },
        { "key": "user_id", "value": "10002", "type": "string" },
        { "key": "movie_id", "value": "24089455", "type": "string" },
        { "key": "task_id", "value": "", "type": "string" }
    ],
    "item": [
        {
            "name": "Health",
            "item": [
                {
                    "name": "GET /api/v1/health",
                    "request": {
                        "method": "GET",
                        "header": [
                            { "key": "X-Internal-Secret", "value": "{{internal_secret}}", "type": "text" }
                        ],
                        "url": {
                            "raw": "{{base_url}}/api/v1/health",
                            "host": [ "{{base_url}}" ],
                            "path": [ "api", "v1", "health" ]
                        }
                    }
                },
                {
                    "name": "GET /api/v1/health/runtime",
                    "request": {
                        "method": "GET",
                        "header": [
                            { "key": "X-Internal-Secret", "value": "{{internal_secret}}", "type": "text" }
                        ],
                        "url": {
                            "raw": "{{base_url}}/api/v1/health/runtime",
                            "host": [ "{{base_url}}" ],
                            "path": [ "api", "v1", "health", "runtime" ]
                        }
                    }
                }
            ]
        },
        {
            "name": "Recommendation",
            "item": [
                {
                    "name": "GET /api/v1/recommend/user",
                    "request": {
                        "method": "GET",
                        "header": [
                            { "key": "X-Internal-Secret", "value": "{{internal_secret}}", "type": "text" }
                        ],
                        "url": {
                            "raw": "{{base_url}}/api/v1/recommend/user?user_id={{user_id}}&n=10",
                            "host": [ "{{base_url}}" ],
                            "path": [ "api", "v1", "recommend", "user" ],
                            "query": [
                                { "key": "user_id", "value": "{{user_id}}" },
                                { "key": "n", "value": "10" }
                            ]
                        }
                    }
                },
                {
                    "name": "GET /api/v1/recommend/item",
                    "request": {
                        "method": "GET",
                        "header": [
                            { "key": "X-Internal-Secret", "value": "{{internal_secret}}", "type": "text" }
                        ],
                        "url": {
                            "raw": "{{base_url}}/api/v1/recommend/item?movie_id={{movie_id}}&n=8",
                            "host": [ "{{base_url}}" ],
                            "path": [ "api", "v1", "recommend", "item" ],
                            "query": [
                                { "key": "movie_id", "value": "{{movie_id}}" },
                                { "key": "n", "value": "8" }
                            ]
                        }
                    }
                },
                {
                    "name": "GET /api/v1/recommend/trending",
                    "request": {
                        "method": "GET",
                        "header": [
                            { "key": "X-Internal-Secret", "value": "{{internal_secret}}", "type": "text" }
                        ],
                        "url": {
                            "raw": "{{base_url}}/api/v1/recommend/trending?window=weekly&n=10",
                            "host": [ "{{base_url}}" ],
                            "path": [ "api", "v1", "recommend", "trending" ],
                            "query": [
                                { "key": "window", "value": "weekly" },
                                { "key": "n", "value": "10" }
                            ]
                        }
                    }
                }
            ]
        },
        {
            "name": "Search",
            "item": [
                {
                    "name": "POST /api/v1/search",
                    "request": {
                        "method": "POST",
                        "header": [
                            { "key": "Content-Type", "value": "application/json", "type": "text" },
                            { "key": "X-Internal-Secret", "value": "{{internal_secret}}", "type": "text" }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"query\": \"sci-fi nolan\",\n  \"n\": 20,\n  \"filters\": {\n    \"genre\": \"Sci-Fi\",\n    \"year_min\": 2010\n  }\n}",
                            "options": { "raw": { "language": "json" } }
                        },
                        "url": {
                            "raw": "{{base_url}}/api/v1/search",
                            "host": [ "{{base_url}}" ],
                            "path": [ "api", "v1", "search" ]
                        }
                    }
                }
            ]
        },
        {
            "name": "Admin",
            "item": [
                {
                    "name": "POST /api/v1/admin/train",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "type": "text/javascript",
                                "exec": [
                                    "const jsonData = pm.response.json();",
                                    "if (jsonData && jsonData.data && jsonData.data.task_id) {",
                                    "  pm.collectionVariables.set('task_id', jsonData.data.task_id);",
                                    "}"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [
                            { "key": "Content-Type", "value": "application/json", "type": "text" },
                            { "key": "X-Internal-Secret", "value": "{{internal_secret}}", "type": "text" }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"component\": \"ranking\",\n  \"model\": \"mmoe\"\n}",
                            "options": { "raw": { "language": "json" } }
                        },
                        "url": {
                            "raw": "{{base_url}}/api/v1/admin/train",
                            "host": [ "{{base_url}}" ],
                            "path": [ "api", "v1", "admin", "train" ]
                        }
                    }
                },
                {
                    "name": "POST /api/v1/admin/refresh",
                    "request": {
                        "method": "POST",
                        "header": [
                            { "key": "X-Internal-Secret", "value": "{{internal_secret}}", "type": "text" }
                        ],
                        "url": {
                            "raw": "{{base_url}}/api/v1/admin/refresh",
                            "host": [ "{{base_url}}" ],
                            "path": [ "api", "v1", "admin", "refresh" ]
                        }
                    }
                },
                {
                    "name": "GET /api/v1/admin/tasks/{task_id}",
                    "request": {
                        "method": "GET",
                        "header": [
                            { "key": "X-Internal-Secret", "value": "{{internal_secret}}", "type": "text" }
                        ],
                        "url": {
                            "raw": "{{base_url}}/api/v1/admin/tasks/{{task_id}}",
                            "host": [ "{{base_url}}" ],
                            "path": [ "api", "v1", "admin", "tasks", "{{task_id}}" ]
                        }
                    }
                },
                {
                    "name": "GET /api/v1/admin/tasks",
                    "request": {
                        "method": "GET",
                        "header": [
                            { "key": "X-Internal-Secret", "value": "{{internal_secret}}", "type": "text" }
                        ],
                        "url": {
                            "raw": "{{base_url}}/api/v1/admin/tasks?source=all&limit=20&offset=0",
                            "host": [ "{{base_url}}" ],
                            "path": [ "api", "v1", "admin", "tasks" ],
                            "query": [
                                { "key": "source", "value": "all" },
                                { "key": "status", "value": "" },
                                { "key": "limit", "value": "20" },
                                { "key": "offset", "value": "0" }
                            ]
                        }
                    }
                },
                {
                    "name": "GET /api/v1/admin/status",
                    "request": {
                        "method": "GET",
                        "header": [
                            { "key": "X-Internal-Secret", "value": "{{internal_secret}}", "type": "text" }
                        ],
                        "url": {
                            "raw": "{{base_url}}/api/v1/admin/status",
                            "host": [ "{{base_url}}" ],
                            "path": [ "api", "v1", "admin", "status" ]
                        }
                    }
                }
            ]
        },
        {
            "name": "RAG",
            "item": [
                {
                    "name": "POST /api/v1/recommend/rag/stream",
                    "request": {
                        "method": "POST",
                        "header": [
                            { "key": "Content-Type", "value": "application/json", "type": "text" },
                            { "key": "Accept", "value": "text/event-stream", "type": "text" },
                            { "key": "X-Internal-Secret", "value": "{{internal_secret}}", "type": "text" }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"query\": \"nolan sci-fi\",\n  \"n\": 8,\n  \"rebuild_index\": false\n}",
                            "options": { "raw": { "language": "json" } }
                        },
                        "url": {
                            "raw": "{{base_url}}/api/v1/recommend/rag/stream",
                            "host": [ "{{base_url}}" ],
                            "path": [ "api", "v1", "recommend", "rag", "stream" ]
                        }
                    }
                }
            ]
        }
    ]
}
